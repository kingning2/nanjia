{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NANJIA BEAUTY",
  "version": "0.1.6",
  "identifier": "com.nanjia.beauty",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm -C .. migrate:sidecar",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NANJIA BEAUTY",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://*.githubusercontent.com https://*.tcb.qcloud.la https://*.myqcloud.com; img-src 'self' data: https: blob:; media-src 'self' https: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyREFCODgwNTlGNjRGNTkKUldSWlQvWlpnTGphRW93N21UTUZ2STA3aUpUbmhmNTU3QVVYaFhjNENXVU5uQnZ1Y3hKaTZmcFkK",
      "endpoints": [
        "https://github.com/kingning2/nanjia/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [],
    "resources": ["bundled-env/*", "resources/cloudbase-migrate/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
