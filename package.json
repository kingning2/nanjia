{
  "name": "nanjia-beauty",
  "version": "1.0.0",
  "private": true,
  "description": "南嘉婚礼策划工作室（Nanjia Beauty）",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "Sass",
    "framework": "React"
  },
  "scripts": {
    "prepare": "husky",
    "new": "taro new",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "install:cf": "node cloud/bundle-cf-shared.js && cd cloud/cf-shared && npm install && cd ../functions/portfolioHome && npm install && cd ../contactConfig && npm install && cd ../socialConfig && npm install && cd ../projectDetail && npm install && cd ../materialCardDetail && npm install && cd ../productCatalog && npm install",
    "deploy:cf": "node scripts/deploy-cloud-functions.mjs",
    "deploy:cf:dev": "node scripts/deploy-cloud-functions.mjs --env development",
    "deploy:cf:test": "node scripts/deploy-cloud-functions.mjs --env test",
    "deploy:cf:prod": "node scripts/deploy-cloud-functions.mjs --env production",
    "cloud:hint": "node -e \"console.log('pnpm deploy:cf:dev | deploy:cf:test | deploy:cf:prod  按环境密钥登录 tcb 并部署全部云函数；单函数: node scripts/deploy-cloud-functions.mjs --env test --fn portfolioHome')\"",
    "sync:project": "node scripts/sync-project-config.mjs",
    "release": "node scripts/release.mjs",
    "migrate:build": "pnpm --filter @nanjia/cloudbase-migrate build",
    "migrate:sidecar": "pnpm --filter @nanjia/cloudbase-migrate build:sidecar",
    "migrate:sidecar:force": "pnpm --filter @nanjia/cloudbase-migrate build:sidecar -- --force",
    "migrate:env": "pnpm migrate:build && pnpm --filter @nanjia/cloudbase-migrate start",
    "predev:weapp": "node scripts/sync-project-config.mjs development",
    "pretest:weapp": "node scripts/sync-project-config.mjs test",
    "prebuild:dev:weapp": "node scripts/sync-project-config.mjs development",
    "prebuild:weapp": "node scripts/sync-project-config.mjs production",
    "prebuild:test:weapp": "node scripts/sync-project-config.mjs test",
    "build:weapp": "npm run clean:dist && node scripts/taro-build-weapp.mjs production",
    "build:dev:weapp": "npm run clean:dist && node scripts/taro-build-weapp.mjs development",
    "build:test:weapp": "npm run clean:dist && node scripts/taro-build-weapp.mjs test",
    "dev:weapp": "taro build --type weapp --watch --env development",
    "test:weapp": "taro build --type weapp --watch --env test"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@nutui/icons-react-taro": "3.0.2-cpp.3.beta.9",
    "@nutui/nutui-react-taro": "3.1.0-beta.1",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.1",
    "@cloudbase/node-sdk": "^3.16.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-generator": "4.2.0",
    "@tarojs/vite-runner": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/minimatch": "^5",
    "@types/react": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-import": "^1.13.8",
    "babel-preset-taro": "4.2.0",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "react-refresh": "^0.14.0",
    "sass": "^1.75.0",
    "stylelint": "^16.4.0",
    "stylelint-config-standard": "^38.0.0",
    "terser": "^5.30.4",
    "typescript": "^5.4.5",
    "vite": "^4.2.0",
    "webpack": "5.91.0"
  }
}
